<%layout("/layouts/boilerplate.ejs")%>
 <div class="row mt-3"> 
    <div class="col-8 offset-2">
    <h3>Create a New Lisitng</h3>
    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
        <label for="title" class="form-label">Enter Title</label>
        <input name="listing[title]" placeholder="enter title" value="<%=listing.title%>" class="form-control"  required>
       <div class="invalid-feedback">Enter valid title</div>
        </div>
       
         <div class="mb-3">
        <lable for="description" class="form-label" >Enter description</lable>
        <input name="listing[description]" placeholder="enter description" value="<%=listing.description%>" class="form-control"  required> 
         </div>
          <div class="mb-3">
            <h3>Original Listing image</h3>
            <img src="<%= originalImage%>">
        </div> 
        <div class="mb-3">
        <lable for="image" class="form-label">Upload new image </lable>
        <input name="listing[image]" class="form-control" type="file">
        </div> 
         <div class="row"> 
        <div class="mb-3 col-md-4">
        <lable for="price" class="form-label" >Enter price</lable>
        <input name="listing[price]" type="number" placeholder="enter price"  value="<%=listing.price%>"class="form-control"  required>
         <div class="invalid-feedback">Enter valid price</div>
        </div>
        
         
         <div class="mb-3 col-md-8">
            <lable for="country" class="form-label" >Enter country</lable>
        <input name="listing[country]"   required placeholder="enter country"  value="<%=listing.country%>"type="text" class="form-control">
         <div class="invalid-feedback">Enter valid country</div>
         </div>
          
         </div>
        <div class="mb-3">
            <lable for="location" class="form-label" >Enter location</lable>
        <input name="listing[location]"  required placeholder="enter location" value="<%=listing.location%>"type="text" class="form-control">
          <div class="invalid-feedback">Enter valid location</div>
        </div>
         
 
         
         
        <button class="btn btn-dark add-btn mt-3">Add</button>
    </form>
    </div>
 </div>